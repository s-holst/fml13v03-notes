regfile timer_rf {
    // Timer [boot-path only]
    reg {
        field {} TODO[31:0];
    } TODO @ 0;
};

regfile coda_llc_rf {
    // CodaCache LLC controller (NPU LLC); reconfigured to SPRAM during boot
    // See coda_llc_spram_init() / FUN_ram_58007ce8
    reg {
        field {} TODO[31:0];
    } TODO @ 0;
    reg {
        field {} busy[0:0]; // 1=busy, 0=ready
    } status @ 0x100;
    reg {
        field {} op[31:0]; // 0xffff=init valid entries, 0x10000=TagArray
    } ccucmwvr @ 0x118;
};

regfile dw_axidma_rf {
    // DW AXI DMA channel control (NPU LLC DMA)
    reg {
        field {} TODO[31:0];
    } TODO @ 0;
    reg {
        field {} ch1_ctl[31:0];
    } ch1_ctl @ 0x118;
};

regfile d2d_rf {
    // Die-to-Die subsystem [boot-path only]
    reg {
        field {} TODO[31:0];
    } TODO @ 0;
    reg {
        field {} data[31:0];
    } firmware1[0x4000] @ 0x50000;
    reg {
        field {} data[31:0];
    } firmware2[0x4000] @ 0x60000;
};

