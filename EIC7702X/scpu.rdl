`include "syscrg_rf.rdl"
`include "syscon_rf.rdl"
`include "otpc_rf.rdl"

regfile clint_rf {
    reg {
        field {} data[31:0];
    } msip @ 0;
    reg {
        regwidth=64;
        field {} data[63:0];
    } mtimecmp @ 0x4000;
    reg {
        regwidth=64;
        field {} data[63:0];
    } mtime @ 0xbff8;
};

regfile plic_rf {
    name = "SCPU security peripherals (0x21Bxxxxx = SCPU view; MCPU alias at 0x51Bxxxxx)";
    reg {
        field {} data[31:0];
    } TODO @ 0;
};


regfile bootspi_rf {
    name = "SPI flash controller [boot-path only]";
    reg {
        field {} data[31:0];
    } TODO @ 0;
};


regfile spacc_rf {
    name = "Synopsys DesignWare Security Protocol Accelerator (AES, SM4)";
    reg {
        field {} TODO[31:0];
    } TODO @ 0;
};

regfile pka_rf {
    name = "Synopsys DesignWare Public Key Accelerator (RSA, ECDSA)";
    reg {
        field {} TODO[31:0];
    } TODO @ 0;
};

regfile trng_rf {
    name = "Synopsys DesignWare True Random Number Generator";
    reg {
        field {} TODO[31:0];
    } TODO @ 0;
};

regfile otp_shadow_rf {
    name = "OTP shadow / secure identity registers (~0x190 bytes)";
    reg {
        field {} TODO[31:0];
    } TODO @ 0;
    reg {
        field {name = "ESWIN vendor ID string written at boot step 4";} vendor_id[31:0];
    } vendor_id @ 0x170;
};

