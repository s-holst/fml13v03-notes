regfile coda_llc_rf {
    name = "CodaCache LLC controller (NPU LLC)";
    desc = "Reconfigured to SPRAM during boot; see coda_llc_spram_init() / FUN_ram_58007ce8";
    reg {
        field {} TODO[31:0];
    } TODO @ 0;
    reg {
        field {name = "1=busy, 0=ready";} busy[0:0];
    } status @ 0x100;
    reg {
        field {name = "0xffff=init valid entries, 0x10000=TagArray";} op[31:0];
    } ccucmwvr @ 0x118;
};

regfile dw_axidma_rf #(string NAME = "DW AXI DMA channel control (NPU LLC DMA)") {
    name = NAME;
    reg {
        field {} TODO[31:0];
    } TODO @ 0;
    reg {
        field {} ch1_ctl[31:0];
    } ch1_ctl @ 0x118;
};

regfile d2d_rf {
    name = "Die-to-Die subsystem [boot-path only]";
    reg {
        field {} TODO[31:0];
    } TODO @ 0;
    reg {
        field {} data[31:0];
    } firmware1[0x4000] @ 0x50000;
    reg {
        field {} data[31:0];
    } firmware2[0x4000] @ 0x60000;
};

