`include "syscrg_rf.rdl"
`include "syscon_rf.rdl"
`include "otp_rf.rdl"

regfile clint_rf {
    reg {
        field {} data[31:0];
    } msip @ 0;
    reg {
        regwidth=64;
        field {} data[63:0];
    } mtimecmp @ 0x4000;
    reg {
        regwidth=64;
        field {} data[63:0];
    } mtime @ 0xbff8;
};

regfile plic_rf {
    reg {
        field {} data[31:0];
    } TODO @ 0;
};


regfile bootspi_rf {
    reg {
        field {} data[31:0];
    } TODO @ 0;
};


regfile spacc_rf {
    // Synopsys DesignWare Security Protocol Accelerator (AES, SM4)
    reg {
        field {} TODO[31:0];
    } TODO @ 0;
};

regfile pka_rf {
    // Synopsys DesignWare Public Key Accelerator (RSA, ECDSA)
    reg {
        field {} TODO[31:0];
    } TODO @ 0;
};

regfile trng_rf {
    // Synopsys DesignWare True Random Number Generator
    reg {
        field {} TODO[31:0];
    } TODO @ 0;
};

regfile otp_shadow_rf {
    // OTP shadow / secure identity registers (~0x190 bytes)
    reg {
        field {} TODO[31:0];
    } TODO @ 0;
    reg {
        field {} vendor_id[31:0]; // ESWIN vendor ID string written at boot step 4
    } vendor_id @ 0x170;
};

regfile pmp_rf {
    // Physical Memory Protection unit (Synopsys DesignWare; FUN_ram_58007ed4)
    reg {
        field {} TODO[31:0];
    } TODO @ 0;
};

